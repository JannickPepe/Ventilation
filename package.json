{
  "name": "huso",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run lint && npx vue-tsc --noEmit && npm run test:run && npm run dev",
    "backend": "cd backend && bundle exec rackup -p 3000",
    "start": "npx concurrently -n api,app -c cyan,magenta \"npm run backend\" \"npm run dev\"",
    "build": "vue-tsc -b && vite build",
    "build:analyze": "vue-tsc -b && vite build --mode analyze",
    "preview": "vite preview",
    "preview:lighthouse": "vite preview --port 4173",
    "lighthouse-report": "npm run build && start-server-and-test preview:lighthouse http://localhost:4173 'npx lighthouse http://localhost:4173 --output=html --output=json --output-path=./lighthouse-report --chrome-flags=--headless --quiet'",
    "lighthouse-check": "npm run build && start-server-and-test preview:lighthouse http://localhost:4173 'node scripts/lighthouse-check.mjs'",
    "lighthouse": "npm run lighthouse-check && npm run lighthouse-report",
    "smoke": "npm run build && start-server-and-test 'vite preview --port 4173' http://localhost:4173 'npx playwright test'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@vee-validate/zod": "^4.14.6",
    "@vueuse/core": "^11.2.0",
    "@vueuse/head": "^2.0.0",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.7.7",
    "pinia": "^2.2.4",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vee-validate": "^4.14.6",
    "vue": "^3.5.12",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.30.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lighthouse": "^12.2.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "start-server-and-test": "^2.0.3",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.6",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "src/**/*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
